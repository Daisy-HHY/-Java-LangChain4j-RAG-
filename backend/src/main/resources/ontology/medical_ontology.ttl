@prefix : <http://www.kgdrug.com#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.kgdrug.com> rdf:type owl:Ontology .

:disease rdf:type owl:Class .
:drug rdf:type owl:Class .
:symptom rdf:type owl:Class .

:haszhengzhuang rdf:type owl:ObjectProperty ;
    rdfs:domain :disease ;
    rdfs:range :symptom ;
    owl:inverseOf :relatedisease .

:relatedisease rdf:type owl:ObjectProperty ;
    rdfs:domain :symptom ;
    rdfs:range :disease .

:needcure rdf:type owl:ObjectProperty ;
    rdfs:domain :disease ;
    rdfs:range :drug ;
    owl:inverseOf :cure .

:cure rdf:type owl:ObjectProperty ;
    rdfs:domain :drug ;
    rdfs:range :disease .

:jibingname rdf:type owl:DatatypeProperty ;
    rdfs:domain :disease ;
    rdfs:range xsd:string .

:proname rdf:type owl:DatatypeProperty ;
    rdfs:domain :drug ;
    rdfs:range xsd:string .

:zzname rdf:type owl:DatatypeProperty ;
    rdfs:domain :symptom ;
    rdfs:range xsd:string .

:bingyin rdf:type owl:DatatypeProperty ;
    rdfs:domain :disease ;
    rdfs:range xsd:string .

:bingfazheng rdf:type owl:DatatypeProperty ;
    rdfs:domain :disease ;
    rdfs:range xsd:string .

:zhiliao rdf:type owl:DatatypeProperty ;
    rdfs:domain :disease ;
    rdfs:range xsd:string .

:yufang rdf:type owl:DatatypeProperty ;
    rdfs:domain :disease ;
    rdfs:range xsd:string .

:gaishu rdf:type owl:DatatypeProperty ;
    rdfs:domain :disease ;
    rdfs:range xsd:string .

:gazhzh rdf:type owl:DatatypeProperty ;
    rdfs:domain :drug ;
    rdfs:range xsd:string .

:pzwh rdf:type owl:DatatypeProperty ;
    rdfs:domain :drug ;
    rdfs:range xsd:string .
